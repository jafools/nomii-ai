# ============================================================
# Shenmay AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Password for the PostgreSQL 'nomii' user.
# (User stays 'nomii' through the Apr 2026 rebrand — renamed in Phase 7.)
DB_PASSWORD=change-me-strong-password

# ------------------------------------------------------------
# SECURITY — REQUIRED IN PRODUCTION
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
JWT_SECRET=change-me-jwt-secret
WIDGET_JWT_SECRET=change-me-widget-jwt-secret
API_KEY_ENCRYPTION_SECRET=change-me-encryption-secret

# ------------------------------------------------------------
# APP URLS
# ------------------------------------------------------------
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
FRONTEND_URL_PROD=
PORTAL_URL=https://your-domain.com

# ------------------------------------------------------------
# AI PROVIDER
# ------------------------------------------------------------
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------
# CLOUDFLARE TUNNEL (optional)
# Create a tunnel at dash.cloudflare.com > Zero Trust > Networks > Tunnels
# Leave blank to use your own reverse proxy (nginx/Caddy) instead.
# ------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# ------------------------------------------------------------
# EMAIL (SMTP)
# Required for advisor notifications, invite emails, document delivery.
# ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Shenmay AI <noreply@your-domain.com>

# ------------------------------------------------------------
# STRIPE (optional — only needed if using subscription billing)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PORTAL_RETURN_URL=https://your-domain.com/shenmay/dashboard/plans

# ------------------------------------------------------------
# MASTER ACCOUNT
# Email that gets a free unlimited subscription on first registration.
# ------------------------------------------------------------
MASTER_EMAIL=you@example.com

# ------------------------------------------------------------
# RATE LIMITING (optional)
# ------------------------------------------------------------
LOGIN_RATE_LIMIT_MAX=3
WIDGET_SESSION_RATE_LIMIT_MAX=6

# ------------------------------------------------------------
# SHENMAY DEPLOYMENT / LICENSE (self-hosted only — see docker-compose.selfhosted.yml)
# ------------------------------------------------------------
# Both SHENMAY_* and NOMII_* are accepted at runtime. The new SHENMAY_* name
# wins if both are set. The old NOMII_* name still works for .env files
# issued before the Apr 2026 rebrand, but you'll see a deprecation warning
# on startup. See docs/SHENMAY_MIGRATION_PLAN.md Phase 8 for removal timeline.
#
# SHENMAY_DEPLOYMENT=selfhosted       # (set in docker-compose.selfhosted.yml; override here if needed)
# SHENMAY_LICENSE_KEY=nomii_da_...    # paid license key (leave blank for trial)
# SHENMAY_INSTANCE_ID=                # optional stable identifier across restarts
# SHENMAY_LICENSE_MASTER=true         # (license-master SaaS only — do NOT set on self-hosted)
